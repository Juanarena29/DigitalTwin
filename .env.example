# Copiá este archivo como `.env` y completá los valores.

# Obligatorio — el chat no responde sin esto
OPENAI_API_KEY=sk-...

# Opcional — protege la pestaña Analytics
DASHBOARD_PASSWORD=tu_contraseña

# Opcional — notificaciones Pushover cuando alguien deja email o agenda call
PUSHOVER_TOKEN=
PUSHOVER_USER=
